# syntax=docker/dockerfile:1
# DEVELOPMENT image — live reload. NOT for production (use ./Dockerfile for that).
FROM maven:3.9-eclipse-temurin-17

# inotify-tools lets us watch the mounted source and recompile on change
RUN apt-get update \
    && apt-get install -y --no-install-recommends inotify-tools \
    && rm -rf /var/lib/apt/lists/*

# Run as the base image's pre-existing uid:gid 1000 user ("ubuntu"), which matches the host
# developer's uid/gid. Files written to the bind-mounted /workspace (including target/) are then
# owned by the host user instead of root, so host-side ./mvnw and the container coexist cleanly.
RUN mkdir -p /home/ubuntu/.m2 && chown -R ubuntu:ubuntu /home/ubuntu
USER ubuntu
ENV HOME=/home/ubuntu
ENV MAVEN_CONFIG=/home/ubuntu/.m2

WORKDIR /workspace

# Pre-download dependencies into the ubuntu user's repo so the first run starts fast.
# (The real source is bind-mounted over /workspace at runtime by compose.)
COPY --chown=ubuntu:ubuntu pom.xml .
RUN mvn -B dependency:go-offline
